Step 14:  Polish and documentation
          - Orval config for TypeScript client codegen from OpenAPI spec
          - README with architecture diagram, quick start, module overview,
            environment variables table
          - Bruno/Postman collection covering all endpoints
          - Final: `docker compose up` from zero, all tests pass, /docs renders
          - Confirm: zero TypeScript errors in strict mode, CI green


# ─────────────────────────────────────────────────────────────────────────────
# 19. WHAT GOOD CODE LOOKS LIKE IN THIS PROJECT
# ─────────────────────────────────────────────────────────────────────────────

# Good — follows all rules
  export async function verifyWalletSignature(
    walletAddress: Address,
    signature: Hex,
    nonce: string,
  ): Promise<Result<User>> {
    const stored = await redis.get(`auth:nonce:${walletAddress}`)
    if (!stored) {
      return { ok: false, error: new UnauthorizedError('NONCE_EXPIRED', 'Nonce expired or not found') }
    }
    const valid = await verifyTypedData({ address: walletAddress, signature, ... })
    if (!valid) {
      return { ok: false, error: new UnauthorizedError('INVALID_SIGNATURE', 'Signature verification failed') }
    }
    await redis.del(`auth:nonce:${walletAddress}`)
    const user = await prisma.user.upsert({
      where: { walletAddress },
      create: { walletAddress },
      update: {},
    })
    return { ok: true, data: user }
  }

# Bad — do not write this
  export async function verifyWalletSignature(walletAddress: any, signature: any) {
    try {
      const nonce = await redis.get(`auth:nonce:${walletAddress}`)
      const valid = await verifyTypedData({ address: walletAddress, signature, ... })
      if (!valid) throw new Error('bad sig')
      const user = await prisma.user.upsert({ where: { walletAddress }, create: { walletAddress }, update: {} })
      return user
    } catch (e) {
      console.error(e)
      throw e
    }
  }


